# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://it_support_admin:your_password_here@localhost:5432/manage_document_db"

# ─── Search Engine ────────────────────────────────────────────────────────────
# Meilisearch binary: chạy meilisearch.exe trước khi start backend
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your_meilisearch_master_key"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Thư mục lưu file upload vật lý (local filesystem)
UPLOAD_DIR="./uploads"

# ─── Redis (Optional) ─────────────────────────────────────────────────────────
# Bỏ comment nếu cài Redis để caching session
# REDIS_URL="redis://localhost:6379"

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT secret key — đặt chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET="replace_with_a_long_random_secret_string_at_least_32_chars"

# ─── AI / RAG Configuration ──────────────────────────────────────────────────
# BƯỚC 1: Chọn một trong hai LLM provider bên dưới:

# Option A: OpenAI (GPT-4o-mini + text-embedding-3-small) — Khuyến nghị
# Lấy API Key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your_openai_api_key_here"
LLM_PROVIDER="openai"

# Option B: Nếu dùng Azure OpenAI (để trống nếu không dùng)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# ─── RAG Tuning ───────────────────────────────────────────────────────────────
# Số chunks retrieve để làm context (khuyến nghị 3-8)
RAG_TOP_K=5
# Ngưỡng cosine similarity tối thiểu (0.0 - 1.0). Giá trị thấp = rộng hơn
RAG_SIMILARITY_THRESHOLD=0.35

# ─── Server ───────────────────────────────────────────────────────────────────
# Port cho NestJS backend (mặc định 3001)
PORT=3001
